Type=Application
Name=MetinRater
Comment=Run Batch Analysis
Exec=sh -c 'for t in x-terminal-emulator gnome-terminal xterm lxterminal konsole kitty; do if command -v $t >/dev/null; then $t -e "/home/onuralp/projects/metinRater/run_batch.sh"; exit; fi; done'
